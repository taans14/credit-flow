// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider     = "prisma-client"
  output       = "../src/generated/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

enum OrderStatus {
  PENDING
  PAID
  FAILED
  CANCELLED
  REFUNDED
}

enum PaymentStatus {
  PENDING
  SUCCESS
  FAILED
  REFUNDED
}

enum CreditTransactionType {
  PURCHASE
  USAGE
  REFUND
  BONUS
  ADMIN_ADJUSTMENT
}

enum UserRole {
  USER
  ADMIN
}

model User {
  id           String   @id @default(uuid()) @db.Uuid
  email        String   @unique
  passwordHash String   @map("password_hash")
  fullName     String?  @map("full_name")
  role         UserRole @default(USER)
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  wallet             UserWallet?
  orders             Order[]
  creditTransactions CreditTransaction[]
  userFeatures       UserFeature[]

  @@map("users")
}

model CreditPackage {
  id          String   @id @default(uuid()) @db.Uuid
  name        String
  description String?
  price       Decimal  @db.Decimal(10, 2)
  credits     Int
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  features PackageFeature[]
  orders   Order[]

  @@map("credit_packages")
}

model Feature {
  id          String   @id @default(uuid()) @db.Uuid
  code        String   @unique
  displayName String   @map("display_name")
  cost        Int      @default(0)
  createdAt   DateTime @default(now()) @map("created_at")

  packages     PackageFeature[]
  userFeatures UserFeature[]

  @@map("features")
}

model UserFeature {
  userId    String @map("user_id") @db.Uuid
  featureId String @map("feature_id") @db.Uuid

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  feature Feature @relation(fields: [featureId], references: [id], onDelete: Cascade)

  @@id([userId, featureId])
  @@map("user_features")
}

model PackageFeature {
  packageId String @map("package_id") @db.Uuid
  featureId String @map("feature_id") @db.Uuid

  creditPackage CreditPackage @relation(fields: [packageId], references: [id], onDelete: Cascade)

  feature Feature @relation(fields: [featureId], references: [id], onDelete: Cascade)

  @@id([packageId, featureId])
  @@map("package_features")
}

model Order {
  id         String      @id @default(uuid()) @db.Uuid
  userId     String      @map("user_id") @db.Uuid
  packageId  String      @map("package_id") @db.Uuid
  totalPrice Decimal     @map("total_price") @db.Decimal(10, 2)
  status     OrderStatus
  createdAt  DateTime    @default(now()) @map("created_at")

  user               User                @relation(fields: [userId], references: [id])
  creditPackage      CreditPackage       @relation(fields: [packageId], references: [id])
  payment            Payment?
  creditTransactions CreditTransaction[]

  @@map("orders")
}

model Payment {
  id              String        @id @default(uuid()) @db.Uuid
  orderId         String        @unique @map("order_id") @db.Uuid
  paymentProvider String?       @map("payment_provider")
  transactionId   String?       @map("transaction_id")
  amount          Decimal       @db.Decimal(10, 2)
  status          PaymentStatus
  paidAt          DateTime?     @map("paid_at")

  order Order @relation(fields: [orderId], references: [id])

  @@map("payments")
}

model UserWallet {
  userId    String   @id @map("user_id") @db.Uuid
  balance   Int      @default(0)
  updatedAt DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id])

  @@map("user_wallets")
}

model CreditTransaction {
  id          String                @id @default(uuid()) @db.Uuid
  userId      String                @map("user_id") @db.Uuid
  orderId     String?               @map("order_id") @db.Uuid
  amount      Int
  type        CreditTransactionType
  description String?
  createdAt   DateTime              @default(now()) @map("created_at")

  user  User   @relation(fields: [userId], references: [id])
  order Order? @relation(fields: [orderId], references: [id])

  @@map("credit_transactions")
}
